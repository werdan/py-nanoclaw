# Copy to .env and fill in. Telegram + OpenAI + OneCLI are required for Docker Compose.

# Optional: override default model in nanoclaw.dispatch (ClaudeAgentOptions.model).
# CLAUDE_MODEL=claude-sonnet-4-20250514
# Optional: image name used by the persistent `agent` compose service.
# NANOCLAW_AGENT_IMAGE=nanoclaw-agent
# Optional: bot -> agent HTTP endpoint inside compose network.
# NANOCLAW_AGENT_URL=http://agent:8000/message
# Local dev: run Claude SDK on the host (no docker agent). Use ONECLI_URL=http://127.0.0.1:10255
# and NANOCLAW_ONECLI_CA_PATH to a host copy of gateway/ca.pem (see LOCAL.md).
# NANOCLAW_AGENT_LOCAL=1
# NANOCLAW_ONECLI_CA_PATH=/tmp/onecli-ca.pem
# Optional: timeout (seconds) for each agent HTTP call.
# NANOCLAW_AGENT_TIMEOUT_S=180
# Optional: persistent scheduler task storage file.
# Default in compose is "/runtime/sessions/.nanoclaw_tasks.json" (mounted/persistent).
# Default outside compose is ".nanoclaw_tasks.json" in current working directory.
# NANOCLAW_TASKS_PATH=/runtime/sessions/.nanoclaw_tasks.json
# Telegram (python -m nanoclaw.telegram_app or nanoclaw-telegram)
TELEGRAM_BOT_TOKEN=
# Required: your numeric Telegram user id (@userinfobot). Only this user may use the bot.
TELEGRAM_USER_ID=
# Required for Telegram voice-note transcription (OpenAI Whisper).
OPENAI_API_KEY=sk-proj-...

# OneCLI: credentials for Claude are managed by OneCLI (passed through to agent containers).
# Full setup (dashboard, agent token, remote SSH tunnel): see DEPLOY.md section "OneCLI setup".
# Postgres for OneCLI (compose service `postgres`); set a strong password in production.
# ONECLI_DB_PASSWORD=onecli
# Default gateway URL matches the `onecli` service in docker-compose.yml.
ONECLI_URL=http://onecli:10255
# OneCLI dashboard API key (`oc_...`), used to fetch SDK container-config from /api/container-config.
ONECLI_API_KEY=
# Optional: OneCLI API base URL override for environments where ONECLI_URL host is not resolvable
# from the bot process (for example, host-side local tests). Default derives from ONECLI_URL and
# swaps :10255 -> :10254.
# NANOCLAW_ONECLI_API_URL=http://127.0.0.1:10254
# Optional: placeholder API key sent to Anthropic through the proxy (OneCLI injects the real secret).
# NANOCLAW_ANTHROPIC_PLACEHOLDER_KEY=placeholder
# Optional: disable HTTP proxy wiring (pass ONECLI_* through unchanged; rarely needed).
# NANOCLAW_ONECLI_PROXY_DISABLE=1

# Optional (recommended in Docker): shared media dir for image temp files.
# NANOCLAW_MEDIA_DIR=/runtime/media

# Optional: used by ops/deploy_remote.sh (git mode) — not read by the Python app.
# NANOCLAW_GIT_REMOTE=https://github.com/you/py-nanoclaw.git
# NANOCLAW_GIT_BRANCH=main

# User context: a git repo subfolder mounted at /work (files appear alongside CLAUDE.md).
# Clone the repo on the host first:
#   git clone https://${GITHUB_PAT}@github.com/you/repo.git data/user-context
# The git-sync service auto-commits and pushes changes every GIT_SYNC_INTERVAL_S seconds.
GITHUB_PAT=ghp_xxxxx
GITHUB_REPO_URL=https://github.com/you/repo
USER_CONTEXT_SUBPATH=YourFolder
# GIT_SYNC_INTERVAL_S=300
